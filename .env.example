# Runtime
AGENT_ENVIRONMENT=local
LOG_LEVEL=INFO

# AWS / Bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
LMD_AWS_REGION=us-east-1
LMD_AWS_ACCESS_KEY_ID=
LMD_AWS_SECRET_ACCESS_KEY=
# Per-agent model defaults:
#   Master orchestrator + final answer default to MODEL_ID (a stronger model) because
#   routing and final-response synthesis have a higher accuracy bar.
#   SQL generation + correction default to MODEL_ID_FAST (Claude Haiku) — these are
#   mechanical, structured tasks, so a faster/cheaper model cuts latency and cost.
# Leave the BEDROCK_MODEL_* values blank to inherit these defaults, or set one to override.
MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
MODEL_ID_FAST=us.anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_MODEL_MASTER=
BEDROCK_MODEL_SQL=
BEDROCK_MODEL_CORRECTOR=
BEDROCK_MODEL_FINAL=

# Redshift analytics
# Use REDSHIFT_URI, DB_URI, or DATABASE_URL_READER as a connection source,
# or provide the explicit REDSHIFT_* values below.
REDSHIFT_URI=
DB_URI=
DATABASE_URL_READER=
REDSHIFT_HOST=
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=kpi_data
REDSHIFT_USER=
REDSHIFT_PASSWORD=
REDSHIFT_SCHEMA=public

# Postgres chat memory
MEM_DB_URI=
TEST_MEM_DB_URI=

# Tuning
SCHEMA_CACHE_TTL_SECONDS=86400
MAX_SQL_RETRIES=1
QUERY_TIMEOUT_SECONDS=30
DEFAULT_LIMIT=100
MAX_LIMIT=1000
MAX_SCHEMA_TABLES_RETURNED=25
